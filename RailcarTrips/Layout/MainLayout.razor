@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="4" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">Railcar Trips</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Elevation="1"
               Anchor="Anchor.Left"
               Class="pa-2">

        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.DirectionsRailway" Match="NavLinkMatch.All">
                Trips
            </MudNavLink>

            <MudNavLink Href="/upload" Icon="@Icons.Material.Filled.UploadFile">
                Upload equipment events CSV
            </MudNavLink>

            <MudNavLink Href="/upload-cities" Icon="@Icons.Material.Filled.UploadFile">
                Upload sities CSV
            </MudNavLink>
        </MudNavMenu>

    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
